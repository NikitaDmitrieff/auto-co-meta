# ============================================================
# Auto-Co Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then either source it or export before running:
#   export $(grep -v '^#' .env | xargs)
# ============================================================

# --- Anthropic ---
# Your Anthropic API key (required)
ANTHROPIC_API_KEY=

# --- Claude Code ---
# Model to use for the autonomous loop (default: opus)
MODEL=opus

# --- Loop Settings ---
# Seconds to wait between cycles (default: 120)
LOOP_INTERVAL=120

# Max seconds per cycle before force-killing Claude (default: 1800 = 30 min)
CYCLE_TIMEOUT_SECONDS=1800

# Number of consecutive errors before circuit breaker trips (default: 3)
MAX_CONSECUTIVE_ERRORS=3

# Seconds to wait after circuit breaker trips (default: 300 = 5 min)
COOLDOWN_SECONDS=300

# Seconds to wait when API usage/rate limit is hit (default: 3600 = 1 hour)
LIMIT_WAIT_SECONDS=3600

# Maximum number of cycle log files to keep (default: 200)
MAX_LOGS=200

# --- Retry & Backoff ---
# Initial backoff seconds on transient failure (default: 30)
RETRY_BASE_SECONDS=30

# Maximum backoff cap in seconds (default: 600 = 10 min)
RETRY_MAX_SECONDS=600

# --- Cycle Limits ---
# Maximum cycles before exit (0 = unlimited, default: 0)
MAX_CYCLES=0

# --- Adaptive Frequency ---
# Seconds to sleep when no changes detected between cycles (default: 600 = 10 min)
# Set to 0 to disable adaptive frequency (always use LOOP_INTERVAL)
IDLE_INTERVAL=600

# --- Memory & State ---
# Enable QMD semantic search integration (default: true)
QMD_ENABLED=true

# Directory for structured state files (default: state)
STATE_DIR=state

# Enable cycle log summaries in logs/summaries/ (default: true)
SUMMARY_ENABLED=true

# --- Webhooks & Notifications ---
# POST JSON notification to this URL after each cycle (empty = disabled)
NOTIFY_URL=

# POST JSON on lifecycle events: start, end, error, circuit break (empty = disabled)
WEBHOOK_URL=

# --- Plugins & Parallelism ---
# Directory with lifecycle hook scripts: pre-cycle.sh, post-cycle.sh (empty = disabled)
PLUGIN_DIR=

# Directory with .md prompt files for parallel Claude sessions (empty = disabled)
PARALLEL_DIR=

# --- Telegram Watcher (watcher.js) ---
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID to send escalation requests to (your personal chat or group)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# How often (ms) to poll Telegram for replies (default: 5000)
WATCHER_POLL_INTERVAL=5000

# How often (ms) to check the request file for changes (default: 3000)
WATCHER_WATCH_INTERVAL=3000

# --- Vercel ---
# Vercel token for deployments (optional if already logged in via CLI)
# VERCEL_TOKEN=

# --- Railway ---
# Railway token for deployments (optional if already logged in via CLI)
# RAILWAY_TOKEN=

# --- Supabase ---
# Supabase access token (optional if already logged in via CLI)
# SUPABASE_ACCESS_TOKEN=

# --- GitHub ---
# GitHub token (optional if already logged in via gh CLI)
# GITHUB_TOKEN=
