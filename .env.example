# ============================================================
# Auto-Co Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then either source it or export before running:
#   export $(grep -v '^#' .env | xargs)
# ============================================================

# --- Claude Code ---
# Model to use for the autonomous loop (default: sonnet)
MODEL=sonnet

# --- Loop Settings ---
# Seconds to wait between cycles (default: 120)
LOOP_INTERVAL=120

# Max seconds per cycle before force-killing Claude (default: 1800 = 30 min)
CYCLE_TIMEOUT_SECONDS=1800

# Number of consecutive errors before circuit breaker trips (default: 3)
MAX_CONSECUTIVE_ERRORS=3

# Seconds to wait after circuit breaker trips (default: 300 = 5 min)
COOLDOWN_SECONDS=300

# Seconds to wait when API usage/rate limit is hit (default: 3600 = 1 hour)
LIMIT_WAIT_SECONDS=3600

# Maximum number of cycle log files to keep (default: 200)
MAX_LOGS=200

# --- Telegram Watcher (watcher.js) ---
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID to send escalation requests to (your personal chat or group)
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# How often (ms) to poll Telegram for replies (default: 5000)
WATCHER_POLL_INTERVAL=5000

# How often (ms) to check the request file for changes (default: 3000)
WATCHER_WATCH_INTERVAL=3000

# --- Vercel ---
# Vercel token for deployments (optional if already logged in via CLI)
# VERCEL_TOKEN=

# --- Railway ---
# Railway token for deployments (optional if already logged in via CLI)
# RAILWAY_TOKEN=

# --- Supabase ---
# Supabase access token (optional if already logged in via CLI)
# SUPABASE_ACCESS_TOKEN=

# --- GitHub ---
# GitHub token (optional if already logged in via gh CLI)
# GITHUB_TOKEN=
